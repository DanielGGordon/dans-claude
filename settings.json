{
  "statusLine": {
    "type": "command",
    "command": "bash /c/Users/dgord/.claude/statusline-command.sh"
  },
  "autoUpdatesChannel": "latest",
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true
  },
  "hooks": {
